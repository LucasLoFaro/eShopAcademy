<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>18fea5e3-04e7-46db-bf68-32f7e00b7fe0</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <DockerfileContext>..\..\..</DockerfileContext>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" Version="1.21.0" />
    <!-- TODO: use the packaged Orders.Domain once the temporary project reference is no longer needed -->
    <!-- <PackageReference Include="eShopAcademy.Orders.Domain" Version="1.0.1" /> -->
    <PackageReference Include="Grpc.Net.ClientFactory" Version="2.80.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.7" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.7">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
	
  <ItemGroup>
    <Protobuf Include="Protos\payment.proto" GrpcServices="Server" />
  </ItemGroup>
  
  <ItemGroup>
    <!-- TODO: remove once the Orders.Domain package workflow is restored -->
    <ProjectReference Include="..\..\..\Domain\Orders.Domain\Orders.Domain.csproj" />
    <ProjectReference Include="..\..\..\ServiceDefaults\ServiceDefaults.csproj" />
    <ProjectReference Include="..\..\Core\Application\Orders.Application.csproj" />
    <ProjectReference Include="..\..\Infrastructure\Clients\Orders.Clients.csproj" />
  </ItemGroup>

</Project>
