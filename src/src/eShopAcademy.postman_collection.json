            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{paymentProviderTxId}}\",\n  \"amount\": 899.99,\n  \"currency\": \"EUR\",\n  \"status\": \"failed\",\n  \"externalId\": \"{{orderId}}\",\n  \"failureReason\": \"Card declined: insufficient funds\"\n}"
            }
          }
        },
        {
          "name": "Webhook - Payment CANCELLED",
