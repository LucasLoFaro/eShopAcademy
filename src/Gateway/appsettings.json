{
"Logging": {
  "LogLevel": {
    "Default": "Information",
    "Microsoft.AspNetCore": "Warning",
    "Yarp.ReverseProxy": "Information"
  }
},
"AllowedHosts": "*",

  "EntraId": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "82abd0e4-97e7-4ad4-9b49-4c93188625ed",
    "ClientId": "f54e2efa-6412-44d1-a342-34229767db5c",
    "Audience": "api://f54e2efa-6412-44d1-a342-34229767db5c"
  },

"ReverseProxy": {
  "Routes": {
    "products-route": {
      "ClusterId": "products-api",
      "Match": {
        "Path": "/api/products/{**catch-all}"
      },
      "Transforms": [
        { "PathRemovePrefix": "/api/products" },
        { "PathPrefix": "/api/product" }
      ]
    },
    "basket-route": {
      "ClusterId": "basket-api",
      "AuthorizationPolicy": "consumer",
      "Match": {
        "Path": "/api/basket/{**catch-all}"
      },
      "Transforms": [
        { "PathRemovePrefix": "/api/basket" },
        { "PathPrefix": "/basket" }
      ],
      "RateLimiterPolicy": "fixed"
    },
    "orders-route": {
      "ClusterId": "orders-api",
      "AuthorizationPolicy": "consumer",
      "Match": {
        "Path": "/api/orders/{**catch-all}"
      },
      "Transforms": [
        { "PathRemovePrefix": "/api/orders" },
        { "PathPrefix": "/Orders" }
      ],
      "RateLimiterPolicy": "fixed"
    },
    "customers-route": {
      "ClusterId": "customers-api",
      "AuthorizationPolicy": "admin",
      "Match": {
        "Path": "/api/customers/{**catch-all}"
      },
      "Transforms": [
        { "PathRemovePrefix": "/api/customers" },
        { "PathPrefix": "/customers" }
      ],
      "RateLimiterPolicy": "fixed"
    },
    "customer-self-route": {
      "ClusterId": "customers-api",
      "AuthorizationPolicy": "consumer",
      "Match": {
        "Path": "/api/me/customer/{**catch-all}",
        "Methods": [ "GET", "POST", "PUT" ]
      },
      "Transforms": [
        { "PathRemovePrefix": "/api/me/customer" },
        { "PathPrefix": "/customers" }
      ],
      "RateLimiterPolicy": "fixed"
    },
    "shipping-route": {
      "ClusterId": "shipping-api",
      "AuthorizationPolicy": "admin",
      "Match": {
        "Path": "/api/shipping/{**catch-all}"
      },
      "Transforms": [
        { "PathRemovePrefix": "/api/shipping" },
        { "PathPrefix": "/api/shipping" }
      ],
      "RateLimiterPolicy": "fixed"
    },
    "operations-route": {
      "ClusterId": "operations-api",
      "AuthorizationPolicy": "admin",
      "Match": {
        "Path": "/api/operations/{**catch-all}"
      },
      "Transforms": [
        { "PathRemovePrefix": "/api/operations" },
        { "PathPrefix": "/api/operations" }
      ],
      "RateLimiterPolicy": "fixed"
    },
    "payments-route": {
      "ClusterId": "payments-api",
      "AuthorizationPolicy": "admin",
      "Match": {
        "Path": "/api/payments/{**catch-all}"
      },
      "Transforms": [
        { "PathRemovePrefix": "/api/payments" },
        { "PathPrefix": "/api/payments" }
      ],
      "RateLimiterPolicy": "fixed"
    }
  },
    "Clusters": {
      "products-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://eshopacademy-products-api"
          }
        }
      },
      "basket-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://eshopacademy-basket-api"
          }
        }
      },
      "orders-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://eshopacademy-orders-api"
          }
        }
      },
      "customers-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://eshopacademy-customers-api"
          }
        }
      },
      "shipping-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://eshopacademy-shipping-api"
          }
        }
      },
      "operations-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://eshopacademy-operations-api"
          }
        }
      },
      "payments-api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://eshopacademy-payments-api"
          }
        }
      }
    }
  }
}
