            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{paymentProviderTxId}}\",\n  \"amount\": 899.99,\n  \"currency\": \"EUR\",\n  \"status\": \"cancelled\",\n  \"externalId\": \"{{orderId}}\",\n  \"failureReason\": \"Customer cancelled the payment\"\n}"
            }
          }
        }
