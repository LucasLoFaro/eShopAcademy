  <ItemGroup>
    <PackageReference Include="Azure.Identity" Version="1.17.1" />
    <PackageReference Include="eShopAcademy.Stock.Domain" Version="1.0.1" />
    <PackageReference Include="Microsoft.Azure.AppConfiguration.AspNetCore" Version="8.4.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\ServiceDefaults\ServiceDefaults.csproj" />
    <ProjectReference Include="..\Data\Stock.Data.csproj" />
    <ProjectReference Include="..\Infrastructure\Services\Stock.Services.csproj" />
  </ItemGroup>

</Project>
