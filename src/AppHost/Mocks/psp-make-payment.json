{
  "request": {
    "method": "POST",
    "urlPath": "/psp/make-payment"
  },
  "response": {
    "status": 200,
    "jsonBody": {
      "result": "ok",
      "id": "{{jsonPath request.body '$.id'}}"
    },
    "transformers": [ "response-template" ]
  },
  "serveEventListeners": [
    {
      "name": "webhook",
      "parameters": {
        "method": "POST",
        "url": "https://webhook.site/5a8009b5-c0a4-454d-9b04-8b98239d6b99",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": "{ \"id\": \"{{jsonPath originalRequest.body '$.id'}}\", \"status\": \"success\", \"user\": \"{{jsonPath originalRequest.body '$.user'}}\" }"
      }
    }
  ]
}