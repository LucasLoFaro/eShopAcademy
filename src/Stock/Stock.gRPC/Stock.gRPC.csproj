<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
		<DockerfileContext>..\..</DockerfileContext>
	</PropertyGroup>

	<ItemGroup>
		<Protobuf Include="Protos\stock.proto" GrpcServices="Server" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Azure.Identity" Version="1.21.0" />
		<!-- TODO: revert to Stock.Domain package once temporary project references are removed -->
		<!-- <PackageReference Include="eShopAcademy.Stock.Domain" Version="1.0.1" /> -->
		<PackageReference Include="Google.Protobuf" Version="3.34.1" />
		<PackageReference Include="Grpc.AspNetCore" Version="2.80.0" />
		<PackageReference Include="Grpc.Tools" Version="2.80.0">
		  <PrivateAssets>all</PrivateAssets>
		  <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.Azure.AppConfiguration.AspNetCore" Version="8.5.0" />
	</ItemGroup>

	<ItemGroup>
		<!-- TODO: remove once Stock.Domain nuget is reinstated -->
		<ProjectReference Include="..\..\Domain\Stock.Domain\Stock.Domain.csproj" />
		<ProjectReference Include="..\..\ServiceDefaults\ServiceDefaults.csproj" />
		<ProjectReference Include="..\Data\Stock.Data.csproj" />
	</ItemGroup>

</Project>
