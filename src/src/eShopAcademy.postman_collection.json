            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"basketClientId\": \"{{basketClientId}}\",\n  \"items\": [\n    {\n      \"productID\": \"{{productId}}\",\n      \"quantity\": 1,\n      \"price\": 899.99\n    }\n  ],\n  \"shippingAddress\": {\n    \"street\": \"Calle Mayor\",\n    \"number\": \"42\",\n    \"additionalInformation\": \"Piso 3A\",\n    \"zipCode\": \"28013\",\n    \"city\": \"Madrid\"\n  }\n}"
            }
          }
        },
        {
          "name": "Place Order (multiple items)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.id) pm.collectionVariables.set('orderId', json.id);",
            "if (json.payment && json.payment.providerTransactionId) {",
            "  pm.collectionVariables.set('paymentProviderTxId', json.payment.providerTransactionId);",
            "}"
          ] } }],
          "request": {
            "method": "POST",
            "url": "{{orders_api}}/Orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"basketClientId\": \"{{basketClientId}}\",\n  \"items\": [\n    {\n      \"productID\": \"{{productId}}\",\n      \"quantity\": 2,\n      \"price\": 899.99\n    },\n    {\n      \"productID\": \"00000000-0000-0000-0000-000000000001\",\n      \"quantity\": 1,\n      \"price\": 249.99\n    }\n  ],\n  \"shippingAddress\": {\n    \"street\": \"Paseo de la Castellana\",\n    \"number\": \"100\",\n    \"additionalInformation\": \"Oficina 512\",\n    \"zipCode\": \"28046\",\n    \"city\": \"Madrid\"\n  }\n}"
            }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "url": "{{orders_api}}/Orders/{{orderId}}"
          }
        }
      ]
