{
  "request": {
    "method": "POST",
    "urlPath": "/psp/make-payment"
  },
  "response": {
    "status": 200,
    "jsonBody": {
      "id": "{{randomValue length=36 type='UUID'}}",
      "externalId": "{{jsonPath request.body '$.OrderId'}}",
      "amount": "{{jsonPath request.body '$.Amount'}}",
      "currency": "{{jsonPath request.body '$.Currency'}}",
      "status": "Created"

    },
    "transformers": [ "response-template" ]
  },
  "serveEventListeners": [
    {
      "name": "webhook",
      "parameters": {
        "method": "POST",
        "url": "https://webhook.site/5a8009b5-c0a4-454d-9b04-8b98239d6b99",
        //"url": "{{jsonPath originalResponse.body '$.NotificationUrl'}}",
        "delay": 1000,
        "headers": {
          "Content-Type": "application/json",
          "X-Signature": "Signature"
        },
        //"body": "{ \"id\": \"{{jsonPath originalRequest.body '$.id'}}\", \"status\": \"success\", \"user\": \"{{jsonPath originalRequest.body '$.user'}}\" }"
        "body": "{ \"id\": \"{{jsonPath originalResponse.body '$.id'}}\", \"amount\": \"{{jsonPath originalRequest.body '$.Amount'}}\", \"currency\": \"{{jsonPath originalRequest.body '$.Amount'}}\", \"Status\": \"Pending\", \"OrderId\": \"{{jsonPath originalRequest.body '$.OrderId'}}\" }"
      }
    }
  ]
}