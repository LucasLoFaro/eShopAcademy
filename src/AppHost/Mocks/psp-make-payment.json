{
  "request": {
    "method": "POST",
    "urlPath": "/psp/make-payment"
  },
  "response": {
    "status": 200,
    "jsonBody": {
      "Id": "{{randomValue type='UUID'}}",
      "Amount": "{{jsonPath request.body '$.Amount'}}",
      "Currency": "{{jsonPath request.body '$.Currency'}}",
      "Status": "Pending",
      "ExternalId": "{{jsonPath request.body '$.ExternalId'}}",
      "Url": "https://psp.com/payment/{{randomValue type='UUID'}}"
    },
    "transformers": [ "response-template" ]
  },
  "serveEventListeners": [
    {
      "name": "webhook",
      "parameters": {
        "method": "POST",
        //"url": "https://webhook.site/ef584cda-0fab-4669-a2da-b6097830c364",
        "url": "{{jsonPath request.body '$.NotificationUrl'}}",
        "delay": {
          "type": "fixed",
          "milliseconds": 1000
        },
        "headers": {
          "Content-Type": "application/json",
          "X-Signature": "Signature"
        },
        "body": "{ \"Id\": \"{{randomValue type='UUID'}}\", \"Amount\": \"{{jsonPath request.body '$.Amount'}}\", \"Currency\": \"{{jsonPath request.body '$.Currency'}}\", \"Status\": \"Success\", \"ExternalId\": \"{{jsonPath request.body '$.ExternalId'}}\" }"
      }
    },
    {
      "name": "webhook",
      "parameters": {
        "method": "POST",
        "url": "https://webhook.site/ef584cda-0fab-4669-a2da-b6097830c364",
        //"url": "{{jsonPath originalRequest.body '$.NotificationUrl'}}",
        "delay": {
          "type": "fixed",
          "milliseconds": 1000
        },
        "headers": {
          "Content-Type": "application/json",
          "X-Signature": "Signature"
        },
        "body": "{ \"Id\": \"{{randomValue type='UUID'}}\", \"Amount\": \"{{jsonPath originalRequest.body '$.Amount'}}\", \"Currency\": \"{{jsonPath originalRequest.body '$.Currency'}}\", \"Status\": \"Success\", \"ExternalId\": \"{{jsonPath originalRequest.body '$.ExternalId'}}\" }"
      }
    }
  ]
}