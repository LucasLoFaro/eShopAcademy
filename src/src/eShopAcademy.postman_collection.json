            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{paymentProviderTxId}}\",\n  \"amount\": 899.99,\n  \"currency\": \"EUR\",\n  \"status\": \"success\",\n  \"externalId\": \"{{orderId}}\"\n}"
            }
          }
        },
        {
          "name": "Webhook - Payment FAILED",
          "request": {
            "method": "POST",
            "url": "{{payments_api}}/api/payments/webhook",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
